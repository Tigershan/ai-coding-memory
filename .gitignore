# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- IDE ----
.idea/
.vscode/
.claude/              # Claude Code workspace local state
*.swp
*.swo
.DS_Store

# ---- Project specific ----
# 用户数据目录由运行时生成，不入库
# （实际数据在 ~/.ai-memory/，此处仅防止误把本地测试数据入库）
.local-data/
*.log
errors.log

# ---- Secrets ----
.env
.env.local
config/config.yml     # 用户私有配置不入库（P3 起 config.yml 替代 domain-mapping）
